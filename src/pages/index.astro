---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import background from "../assets/bg1-desktop-webp.png";
import CircuitBackground from "../components/CircuitBackground.astro";
import { Image } from "astro:assets";
import VirtusApex from "../assets/astro-framework1720735660.logowik.com-Recuperado2.png";
import astroLogoFull from "../assets/logo-astra.png";
import LogoApex from "../assets/logo-apex.png";

import drogariaImg from "../assets/drogariacruzeiro_.jpg";
import moradaImg from "../assets/moradadossonhoswr.jpg";
import raquelImg from "../assets/psicraquelmarques.jpg";
import remaImg from "../assets/rema.engenharia_.jpg";
import studioImg from "../assets/studio_ragonete.jpg";
import virtusImg from "../assets/virtus_doctor.png";

import frameImg from "../assets/frame_43.webp";
import baseImg from "../assets/MOCKUP-BASE-matheus-santos.webp";

const teamMembers = [
	{ id: 1, handle: "@drogariacruzeiro", img: drogariaImg },
	{ id: 2, handle: "@moradadossonhoswr", img: moradaImg },
	{ id: 3, handle: "@psic.raquelmarques", img: raquelImg },
	{ id: 4, handle: "@rema.engenharia", img: remaImg },
	{ id: 5, handle: "@studio.ragonete", img: studioImg },
	{ id: 6, handle: "@virtus.doctor", img: virtusImg },
];

const carouselItems = [
	"+ Confiança",
	"+ Personalização",
	"+ Comunicação",
	"+ Profissionalismo",
	"- Perdas",
	"+ Conversões",
];

const benefits = [
	{
		title: "+ Conversões",
		text: "Uma landing page bem projetada com um design impactante pode ajudar a aumentar as taxas de conversão, incentivando mais visitantes a se inscreverem ou comprarem o produto lançado.",
	},
	{
		title: "+ Confiança",
		text: "Um design impactante e uma apresentação bem estruturada ajudam a criar uma imagem confiável e segura do seu produto, aumentando a probabilidade de que os visitantes se sintam confortáveis ao fornecer suas informações.",
	},
	{
		title: "+ Personalização",
		text: "Uma landing page de alto padrão entrega uma personalização na experiência do usuário e faz um apelo mais emocional aos visitantes, incentivando-os a tomar medidas para se envolver com o seu produto.",
	},
	{
		title: "+ Comunicação",
		text: "Uma landing page bem projetada permite que você se comunique claramente com seus visitantes, oferecendo informações úteis sobre o produto, seus recursos e benefícios, e incentivando-os a agir.",
	},
	{
		title: "+ Profissionalismo",
		text: "Uma landing page de alta qualidade mostra que você leva a sério o seu negócio e está disposto a investir tempo e recursos em seus lançamentos de produtos digitais, criando uma impressão profissional nos visitantes.",
	},
	{
		title: "- Perdas",
		text: "Uma landing page de alto padrão consegue transmitir mais credibilidade na sua oferta, fazendo com que quando seu lead acessar sua página ele terá certeza que se trata de algo profissional, diminuindo as incertezas.",
	},
];
---

<Layout title="Vinícius Benevides | Landing Pages Exclusivas">
	<style is:global>
		@font-face {
			font-family: "Paralucent";
			src: url("/src/fonts/fonnts.com-Paralucent_Medium.otf")
				format("opentype");
			font-weight: medium;
			font-style: normal;
			font-display: swap;
		}

		@font-face {
			font-family: "Paralucent";
			src: url("/src/fonts/fonnts.com-Paralucent_Light.otf")
				format("opentype");
			font-weight: light;
			font-style: normal;
			font-display: swap;
		}
	</style>

	<style>
		:root {
			--c1: rgba(154, 235, 247, 1);
			--c2: rgba(154, 235, 247, 0.1);
			/* Cor do Container dos Cards (Mais clara que o fundo preto) */
			--card-section-bg: #15171ebf;
		}

		/* --- Animações do Spinner --- */
		@keyframes borderRotate {
			100% {
				--angle: 420deg;
			}
		}

		@keyframes flash-interval {
			0%,
			100% {
				opacity: 0;
			}
			5% {
				opacity: 0.95;
			}
			10% {
				opacity: 0;
			}
		}

		.conic-spinner {
			background: conic-gradient(
				from var(--angle),
				var(--c2),
				var(--c1) 0.1turn,
				var(--c1) 0.15turn,
				var(--c2) 0.25turn
			);
			animation: borderRotate 2500ms linear infinite forwards;
		}

		.flash-overlay {
			animation: flash-interval 3.8s ease-in-out infinite;
		}

		/* --- Infinite Scroll --- */
		@keyframes infinite-scroll {
			from {
				transform: translateX(0);
			}
			to {
				transform: translateX(-50%);
			}
		}

		.animate-infinite-scroll {
			animation: infinite-scroll 40s linear infinite;
		}

		.mask-gradient {
			mask-image: linear-gradient(
				to right,
				transparent,
				black 10%,
				black 90%,
				transparent
			);
			-webkit-mask-image: linear-gradient(
				to right,
				transparent,
				black 10%,
				black 90%,
				transparent
			);
		}

		/* --- Estilos do Carrossel --- */
		.carousel-section {
			position: relative;
			width: 100vw;
			max-width: 100%;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 100px 0;
			overflow: hidden;
			-webkit-mask-image: linear-gradient(
				to right,
				transparent,
				black 15%,
				black 85%,
				transparent
			);
			mask-image: linear-gradient(
				to right,
				transparent,
				black 15%,
				black 85%,
				transparent
			);
		}

		.laptop-base {
			margin-top: -7px;
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			z-index: 15;
			pointer-events: none;
			width: 700px;
		}

		.laptop-base img {
			width: 100%;
			height: auto;
			display: block;
			object-fit: contain;
		}

		.laptop-frame-overlay {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			z-index: 10;
			pointer-events: none;
			width: 625px;
			height: 365px;
		}

		.laptop-frame-overlay img {
			width: 625px;
			height: 393px;
			display: block;
			object-fit: contain;
		}

		.swiper {
			width: 100%;
			overflow: visible;
			z-index: 5;
		}

		.swiper-slide {
			width: 530px;
			height: 360px;
			border-radius: 15px;
			overflow: hidden;
		}

		.swiper-slide img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			object-position: top;
		}

		@media (max-width: 768px) {
			.laptop-frame-overlay {
				width: 340px;
				height: 213px;
			}
			.laptop-frame-overlay img {
				width: 340px;
				height: 213px;
			}
			.laptop-base {
				width: 380px;
				transform: translate(-50%, calc(-50% + 105px));
			}
			.swiper-slide {
				width: 258px !important;
				height: 162px;
			}
			/* Ajuste do gradiente para telas menores para não "comer" muito a tela */
			.carousel-section {
				-webkit-mask-image: linear-gradient(
					to right,
					transparent,
					black 5%,
					black 95%,
					transparent
				);
				mask-image: linear-gradient(
					to right,
					transparent,
					black 5%,
					black 95%,
					transparent
				);
			}
		}
	</style>

	<main
		class="min-h-screen w-full bg-cover bg-center bg-no-repeat flex flex-col items-center text-center px-4 relative overflow-hidden pb-0"
		style={`background-image: url(${background.src});`}
	>
		<div class="absolute inset-0"></div>

		<CircuitBackground />

		{/* --- Header Content --- */}
		<div
			class="w-full max-w-5xl relative z-10 flex flex-col items-center h-full"
		>
			<div
				class="mt-10 mb-8 opacity-100 hover:opacity-100 transition-opacity duration-500"
			>
				<Image
					src={VirtusApex}
					alt="Astro Framework Logo"
					width={324.5}
					height={75}
					class="object-contain"
				/>
			</div>

			<div class="flex flex-col items-center justify-center mb-8">
				<span
					id="scramble-text"
					class="font-medium tracking-wide leading-none"
					style="font-family: 'Paralucent', sans-serif; font-size: 74px; color: #e8ebf0;"
				>
					Landing Pages
				</span>

				<h2
					class="font-medium leading-[1.1] mt-1.5"
					style="font-family: 'Paralucent', sans-serif; font-size: 56px; max-width: 800px;"
				>
					<span style="color: #ABAEB4;">que vendem,</span>
					<span class="block md:inline" style="color: #E8EBF0;">
						para projetos que conquistam resultados.
					</span>
				</h2>

				<p
					class="font-light mt-5 max-w-2xl mx-auto leading-relaxed"
					style="font-family: 'Paralucent', sans-serif; font-size: 20px; color: #E8EBF0;"
				>
					Entenda como um projeto digital maduro, construído com
					estratégia, é o diferencial que separa quem lidera o nicho
					de quem apenas participa dele.
				</p>

				{/* Spinner Button */}
				<div
					class="mt-10 relative group w-[380px] h-[75px] mx-auto cursor-pointer z-10"
				>
					<div
						class="absolute -inset-10 rounded-full bg-white/20 opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-100"
					>
					</div>
					<div
						class="flash-overlay absolute inset-0 rounded-full bg-white pointer-events-none z-20 mix-blend-overlay"
					>
					</div>
					<div
						class="absolute inset-0 rounded-full overflow-hidden p-[1.5px] bg-[#5C666F]"
					>
						<div
							class="conic-spinner absolute inset-[-100%] w-[300%] h-[300%] left-[-100%] top-[-100%]"
						>
						</div>
						<div
							class="h-full w-full bg-[#0F1115] rounded-full relative z-10"
						>
						</div>
					</div>
					<span
						class="absolute top-0 left-[37.5px] w-[2px] h-[2px] bg-white rounded-full z-20 shadow-[0_0_2px_white]"
					></span>
					<span
						class="absolute top-0 right-[37.5px] w-[2px] h-[2px] bg-white rounded-full z-20 shadow-[0_0_2px_white]"
					></span>
					<span
						class="absolute bottom-0 left-[37.5px] w-[2px] h-[2px] bg-white rounded-full z-20 shadow-[0_0_2px_white]"
					></span>
					<span
						class="absolute bottom-0 right-[37.5px] w-[2px] h-[2px] bg-white rounded-full z-20 shadow-[0_0_2px_white]"
					></span>
					<a
						href="https://wa.me/5562981752097?text=Ol%C3%A1%2C+gostaria+de+solicitar+um+or%C3%A7amento."
						target="_blank"
						rel="noopener noreferrer"
						class="absolute inset-0 z-30 flex items-center justify-center rounded-full"
					>
						<span
							class="tracking-widest font-medium mr-4"
							style="font-family: 'Paralucent', sans-serif; font-size: 18px; color: #E8EBF0;"
						>
							ENVIAR MENSAGEM
						</span>
						<span
							class="transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="26"
								height="26"
								viewBox="0 0 24 24"
								fill="none"
							>
								<path
									d="M5 19.5L19.5 5"
									stroke="#9AEBF7"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
								<path
									d="M9.5 5H19.5V15"
									stroke="#9AEBF7"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
							</svg>
						</span>
					</a>
				</div>

				{/* Team Avatars */}
				<div
					class="mt-15 w-full flex flex-col md:flex-row items-center justify-center gap-8 relative z-20"
				>
					<div class="flex items-center justify-center group">
						{
							teamMembers.map((member, index) => (
								<div
									class={`relative w-16 h-16 md:w-[72px] md:h-[72px] rounded-full border-[3px] border-[#0F1115] overflow-visible transition-all duration-300 ease-in-out group/item group-hover:grayscale hover:!grayscale-0 hover:scale-110 z-0 hover:z-20 ${index > 0 ? "-ml-5" : ""}`}
								>
									<img
										src={member.img.src}
										alt={member.handle}
										class="w-full h-full rounded-full object-cover"
									/>
									<span
										class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 px-3 py-1.5 bg-[#15171c] border border-[#9AEBF7]/30 text-[#9AEBF7] text-xs font-medium tracking-wider rounded-md opacity-0 invisible group-hover/item:opacity-100 group-hover/item:visible transition-all duration-300 whitespace-nowrap shadow-[0_0_15px_rgba(154,235,247,0.2)]"
										style="font-family: 'Paralucent', sans-serif;"
									>
										{member.handle}
										<span class="absolute top-full left-1/2 -translate-x-1/2 -mt-[1px] border-4 border-transparent border-t-[#15171c]" />
									</span>
								</div>
							))
						}
					</div>
					<div class="text-center md:text-left max-w-xs">
						<p
							class="font-light leading-tight"
							style="font-family: 'Paralucent', sans-serif; font-size: 18px; color: #ABAEB4"
						>
							Dezenas de projetos entregues e clientes atendidos!
						</p>
					</div>
				</div>
			</div>
		</div>
	</main>

	{/* --- SEÇÃO INFERIOR --- */}
	<div class="w-full bg-[#06060E] relative pb-24">
		{/* Infinite Scroll Strip */}
		<div class="py-2 border-y border-white/10 bg-[#202229] relative z-20">
			<div class="overflow-hidden mask-gradient w-full">
				<div
					class="flex w-max animate-infinite-scroll gap-8 items-center"
					style="animation-duration: 80s;"
				>
					{
						Array(12)
							.fill(carouselItems)
							.flat()
							.map((item) => (
								<div
									class="px-8 py-2.5 cursor-pointer rounded-full bg-[#0F1115] border border-[#1f2125] text-[#ABAEB4] font-medium whitespace-nowrap hover:border-[#3a3d45] hover:text-white transition-colors duration-300"
									style="font-family: 'Paralucent', sans-serif;font-size: 16px;"
								>
									{item}
								</div>
							))
					}
				</div>
			</div>
		</div>

		{/* --- 1. ONDAS EM CANVAS (Z-INDEX 0: Atrás dos cards) --- */}
		<div
			class="absolute inset-0 z-0 pointer-events-none overflow-hidden h-full flex items-center justify-center"
		>
			<canvas id="wave-canvas" class="w-full h-full"></canvas>
		</div>

		{/* 2. CONTAINER DOS CARDS (Z-INDEX 10: Acima das ondas) */}
		<div class="w-full px-4 mt-20 relative z-10">
			{/* Bloco Principal do Card */}
			<div
				class="max-w-7xl mx-auto rounded-b-[40px] md:rounded-b-[60px] relative shadow-2xl shadow-black/50"
				style="background-color: var(--card-section-bg);"
			>
				{/* --- HEADER DO CARD (A Curva "Derretida") --- */}
				<div
					class="absolute -top-[40px] left-0 right-0 h-[41px] flex items-end justify-center w-full overflow-visible pointer-events-none"
				>
					<div
						class="h-full flex-1 rounded-tl-[40px] md:rounded-tl-[60px]"
						style="background-color: var(--card-section-bg);"
					>
					</div>
					<div class="relative w-[180px] h-full shrink-0">
						<svg
							width="100%"
							height="100%"
							viewBox="0 0 180 41"
							preserveAspectRatio="none"
							fill="none"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								d="M0 0C0 0 30 0 30 0C55 0 65 38 90 38C115 38 125 0 150 0C150 0 180 0 180 0V41H0V0Z"
								fill="#15171ebf"></path>
						</svg>
						<div
							class="absolute top-[8px] left-1/2 -translate-x-1/2 text-[#ABAEB4]"
						>
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									d="M6 9L12 15L18 9"
									stroke="currentColor"
									stroke-width="2.5"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
							</svg>
						</div>
					</div>
					<div
						class="h-full flex-1 rounded-tr-[40px] md:rounded-tr-[60px]"
						style="background-color: var(--card-section-bg);"
					>
					</div>
				</div>

				{/* Conteúdo do Card (Texto e Grid) */}
				<div
					class="relative z-10 px-6 pt-12 pb-16 md:px-12 md:pb-20 md:pt-16"
				>
					<h2
						class="text-center text-3xl md:text-4xl mb-16 font-medium text-[#ABAEB4]"
						style="font-family: 'Paralucent', sans-serif;"
					>
						Como uma <span class="text-[#E8EBF0] font-bold"
							>Página</span
						> de alto padrão pode te ajudar :
					</h2>

					<div
						class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
					>
						{
							benefits.map((item) => (
								<div class="group p-8 rounded-3xl bg-[#0a0b0f] border border-[#1f2125] hover:border-[#9AEBF7]/30 transition-all duration-300 hover:-translate-y-1">
									<h3
										class="text-xl font-bold mb-4 text-[#E8EBF0] group-hover:text-[#9AEBF7] transition-colors"
										style="font-family: 'Paralucent', sans-serif;"
									>
										{item.title}
									</h3>
									<p
										class="text-[#ABAEB4] text-sm leading-relaxed font-light"
										style="font-family: 'Paralucent', sans-serif;"
									>
										{item.text}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>

		{/* --- 3. CARROSSEL COM FRAME --- */}
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
		/>
		<section class="carousel-section mt-10 relative z-20">
			<div class="laptop-base">
				<img src={baseImg.src} alt="Base do Notebook" />
			</div>

			<div class="laptop-frame-overlay">
				<img src={frameImg.src} alt="Frame do Computador" />
			</div>

			<div class="swiper mySwiper">
				<div class="swiper-wrapper">
					<div class="swiper-slide">
						<img
							src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800&q=80"
							alt="Tela 1"
						/>
					</div>
					<div class="swiper-slide">
						<img
							src="https://images.unsplash.com/photo-1504639725590-34d0984388bd?auto=format&fit=crop&w=800&q=80"
							alt="Tela 2"
						/>
					</div>
					<div class="swiper-slide">
						<img
							src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=800&q=80"
							alt="Tela 3"
						/>
					</div>
					<div class="swiper-slide">
						<img
							src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&q=80"
							alt="Tela 4"
						/>
					</div>
					<div class="swiper-slide">
						<img
							src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800&q=80"
							alt="Tela 1"
						/>
					</div>
					<div class="swiper-slide">
						<img
							src="https://images.unsplash.com/photo-1504639725590-34d0984388bd?auto=format&fit=crop&w=800&q=80"
							alt="Tela 2"
						/>
					</div>
				</div>
			</div>
		</section>

		{/* Scripts do Swiper */}
		<script
			is:inline
			src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
		></script>
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				const swiper = new Swiper(".mySwiper", {
					slidesPerView: "auto",
					centeredSlides: true,
					spaceBetween: 50,
					loop: true,
					speed: 2000,
					autoplay: {
						delay: 2000,
						disableOnInteraction: false,
					},
				});
			});
		</script>

		{/* --- SEÇÃO DE CAPTURA (abaixo do carrossel) --- */}
		<section class="capture-section py-24 relative z-20">
			<div class="max-w-4xl mx-auto text-center px-6">
				<h2
					class="font-medium mb-6"
					style="font-family: 'Paralucent', sans-serif; font-size:48px; color:#E8EBF0; line-height:1.05;"
				>
					Como uma <span style="color:#E8EBF0; font-weight:800"
						>Página de Alto Padrão</span
					> pode te ajudar a ter mais resultados
				</h2>
				<p
					class="mb-8"
					style="font-family: 'Paralucent', sans-serif; color:#ABAEB4; font-size:18px; max-width:900px; margin:0 auto;"
				>
					Quando o seu lead acessa a sua página para se inscrever no
					seu evento, ou comprar seu produto, essa página precisa
					refletir fielmente a premissa da sua oferta. Caso contrário,
					ela não vai trazer credibilidade e você pode perder o lead e
