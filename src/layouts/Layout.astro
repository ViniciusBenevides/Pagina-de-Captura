---
// 1. IMPORTANDO O CSS DO TAILWIND
// Isso avisa pro site carregar os estilos globais
import "../styles/global.css";
import LoaderScreen from "../components/LoaderScreen.astro";

// 2. DEFININDO AS PROPRIEDADES
// Isso permite que você mude o título da aba do navegador em cada página
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Especialista em Landing Pages de Alta Conversão. Transforme curiosos em clientes com designs exclusivos e de alto desempenho."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo-apex.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph / WhatsApp / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://virtusapex.com/" />
		<!-- Substitua pelo seu domínio oficial -->
		<meta property="og:title" content="Virtus Apex" />
		<meta
			property="og:description"
			content="Especialista em Landing Pages de Alta Conversão. Transforme curiosos em clientes com designs exclusivos e de alto desempenho."
		/>
		<meta
			property="og:image"
			content="https://virtusapex.com/og-image.png"
		/>
		<!-- Adicione sua imagem de capa (ex: 1200x630) na pasta public com o nome og-image.png -->

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://virtusapex.com/" />
		<meta property="twitter:title" content="Virtus Apex" />
		<meta
			property="twitter:description"
			content="Especialista em Landing Pages de Alta Conversão. Transforme curiosos em clientes com designs exclusivos e de alto desempenho."
		/>
		<meta
			property="twitter:image"
			content="https://virtusapex.com/og-image.png"
		/>

		<title>{title}</title>
	</head>
	<body>
		<LoaderScreen />
		<slot />
		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const observerOptions = {
					root: null,
					rootMargin: "0px",
					threshold: 0.15,
				};

				const observer = new IntersectionObserver(
					(entries, observer) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
					},
					observerOptions,
				);

				document
					.querySelectorAll(".animate-on-scroll")
					.forEach((el) => {
						observer.observe(el);
					});
			});
		</script>
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		overflow-x: hidden;
	}

	/* Animation utility classes */
	.animate-on-scroll {
		opacity: 0;
		transform: translateY(30px);
		transition:
			opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
			transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
		will-change: opacity, transform;
	}

	.animate-on-scroll.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.delay-100 {
		transition-delay: 100ms;
	}
	.delay-200 {
		transition-delay: 200ms;
	}
	.delay-300 {
		transition-delay: 300ms;
	}
</style>
